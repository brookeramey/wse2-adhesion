&CONTROL
  calculation   = 'scf'
  prefix        = 'wse2_cleave_001'
  outdir        = './tmp/cleave_001/'
  pseudo_dir    = './pseudo/'
  verbosity     = 'low'
  forc_conv_thr = 1.0e-3
/

&SYSTEM
  ibrav=4
  a=3.28
  c=50.0
  nat=6
  ntyp=2
  ecutwfc=80.0
  ecutrho=640.0
  occupations='smearing'
  smearing='m-p'
  degauss=0.02
  input_dft='vdw-df2-b86r'
/

&ELECTRONS
  mixing_mode      = 'local-TF'
  mixing_beta      = 0.1
  conv_thr         = 1.0e-7
  electron_maxstep = 200
  mixing_ndim      = 12
/

ATOMIC_SPECIES
  W   183.84   W.pbe-spn-kjpaw_psl.1.0.0.UPF
  Se  78.960   Se.pbe-dn-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS crystal
  Se 0.333333  0.666667  0.401140
  W  0.000000  0.000000  0.435474
  Se 0.666667  0.333333  0.469817
  Se 0.333333  0.666667  0.534155
  W  0.666667  0.333333  0.568480
  Se 0.000000  0.000000  0.602860

K_POINTS automatic
16 16 1 0 0 0
