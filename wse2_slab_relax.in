&CONTROL
  calculation   = 'relax'
  prefix        = 'wse2_relax'
  outdir        = './tmp/relax/'
  pseudo_dir    = './pseudo/'
  verbosity     = 'low'
  tprnfor       = .true.
  tstress       = .false.
  forc_conv_thr = 1.0e-3
/

&SYSTEM
  ibrav=4
  a=3.28
  c=30.0
  nat=6
  ntyp=2
  ecutwfc=80.0
  ecutrho=640.0
  occupations='smearing'
  smearing='m-p'
  degauss=0.02
  input_dft='vdw-df2-b86r'
/

&ELECTRONS
  mixing_mode   = 'local-TF'
  mixing_beta   = 0.3
  conv_thr      = 1.0e-8
/

&IONS
  ion_dynamics  = 'bfgs'
  upscale       = 100
/

ATOMIC_SPECIES
  W   183.84   W.pbe-spn-kjpaw_psl.1.0.0.UPF
  Se  78.960   Se.pbe-dn-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS crystal
  Se  0.333333  0.666667  0.064
  W   0.000000  0.000000  0.120
  Se  0.666667  0.333333  0.176
  Se  0.333333  0.666667  0.279
  W   0.666667  0.333333  0.335
  Se  0.000000  0.000000  0.391

K_POINTS automatic
16 16 1 0 0 0
